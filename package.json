{
  "name": "mojioko",
  "version": "1.3.3",
  "description": "Local video transcription and subtitle burn-in tool",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "rimraf out dist && npm run build && electron-builder --win",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "scan:pii": "node scripts/pii-scan.mjs",
    "setup:hooks": "git config core.hooksPath scripts/hooks",
    "msix:register": "powershell -ExecutionPolicy Bypass -NoProfile -File scripts/msix-register-sideload.ps1",
    "msix:register:skip-build": "powershell -ExecutionPolicy Bypass -NoProfile -File scripts/msix-register-sideload.ps1 -SkipBuild"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron-log": "^5.1.5",
    "framer-motion": "^11.3.0",
    "i18next": "^23.12.2",
    "lucide-react": "^0.400.0",
    "opentype.js": "^2.0.0",
    "react": "^18.3.1",
    "react-colorful": "^5.7.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "react-i18next": "^14.1.3",
    "react-resizable-panels": "^4.11.2",
    "react-router-dom": "^6.24.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.9",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.1.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
