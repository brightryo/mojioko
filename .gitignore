# ============================================
# MOJIOKO .gitignore
# ============================================
# このファイルの管理方針は dev-docs/GIT_GUIDE.md を参照。

# ============================================
# 依存関係（パッケージマネージャ管理）
# ============================================
node_modules/

# ============================================
# ビルド成果物（再生成可能、大容量）
# ============================================

# Electron ビルド
dist/
out/
release/

# REQ-0166 — MSIX ビルド成果物 (electron-builder appx target).  4 GB 級の
# .appx / loose-file expansion / signing 中間物が入るため絶対に追跡しない。
dist-appx/

# Python sidecar ビルド
python-sidecar/dist/
python-sidecar/build/
python-sidecar/__pycache__/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
# PyInstaller の同梱物（resources/bin/transcriber/）は同梱方針 α により Git 管理対象。
# 上の **/*.pyd が意図せず native 拡張モジュールを除外しないよう negation で復活させる。
# （ctranslate2.models / tokenizers.models など Python パッケージ submodule の
# negation は、対応する `models/` 排除パターンの後ろに配置する必要があるため、
# ファイル下方の Whisper モデルファイル節の直後に置いている — gitignore は
# 「最後にマッチしたパターンが勝つ」ため、negation は対応する排除より後段でないと
# 効かない。）
!resources/bin/transcriber/**/*.pyd

# TypeScript ビルドキャッシュ
*.tsbuildinfo

# Electron Builder ビルドキャッシュ
.electron-builder/

# Vite ビルドキャッシュ
.vite/
node_modules/.vite/

# その他ビルドキャッシュ
.cache/
.parcel-cache/
.turbo/

# ============================================
# Python 仮想環境
# ============================================
.venv/
.venv-*/
venv/
env/

# ============================================
# ログファイル
# ============================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# 環境変数（秘密情報を含む可能性）
# ============================================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ============================================
# IDE・エディタ設定（個人環境依存）
# ============================================

# VS Code
.vscode/
!.vscode/settings.json.example  # 必要なら共有設定の雛形は許可

# JetBrains
.idea/
*.iml
*.iws

# Vim / Emacs
*.swp
*.swo
*~
.DS_Store

# Claude Code
.claude/

# ============================================
# OS 固有ファイル
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================
# テスト・カバレッジ
# ============================================
coverage/
*.lcov
.nyc_output/
junit.xml
.vitest-cache/

# ============================================
# 一時ファイル
# ============================================
*.tmp
*.temp
*.bak
*.backup

# 配布用一時 zip ファイル（Claude との作業で生成されるもの）
docs.zip
release-docs.zip
*.zip.tmp

# ============================================
# 作業報告 (REQ/RES サイクル)
# ============================================
# 依頼ごとに書き出す RES-YYYYMMDD-NNN.md は dev-docs/reports/ に集約する。
# チャット貼り付け用のローカル参照専用なので Git 管理外。
# 運用ルールの全文は CLAUDE.md §17 を参照。
dev-docs/reports/

# ============================================
# 同梱バイナリのうち、本番ビルドに含めないもの
# ============================================

# ffplay.exe は electron-builder の extraResources で除外されているため Git 管理不要
resources/bin/ffmpeg/ffplay.exe

# REQ-0236 — CUDA / cuDNN ランタイム DLL は GitHub Releases の cuda-v1.zip として
# on-demand DL する運用 (src/shared/gpu-tool.ts)。PyInstaller の rebuild で
# _internal/ctranslate2/ 配下に大容量 DLL (>100MB) が再度混入するのを防ぐため
# gitignore で塞ぐ。REQ-0146 で 11 個 (~1.5GB) を一度追跡し REQ-0148/0149 で
# 削除したが、履歴に blob が残って push がリジェクトされた事案 (REQ-0236) を
# 受けた再発防止措置。既に追跡済みの DLL (ctranslate2.dll など) には影響なし。
resources/bin/transcriber/_internal/ctranslate2/*.dll

# ============================================
# Whisper モデルファイル（ユーザー環境にのみ存在、絶対に追跡しない）
# ============================================
models/
*.bin
*.pt
# PyInstaller の同梱物に含まれる Python パッケージ submodule (ctranslate2.models,
# tokenizers.models 等) は上の `models/` で誤って除外されてしまうため negation で復活。
# 配置位置注意: gitignore は最後にマッチしたパターンが勝つので、対応する `models/`
# 排除よりも後段（このブロック内）に置く必要がある。
!resources/bin/transcriber/_internal/**/models/
!resources/bin/transcriber/_internal/**/models/**

# ============================================
# プロファイリング・デバッグ出力
# ============================================
*.cpuprofile
*.heapprofile
*.heapsnapshot
chrome-debug.log

# ============================================
# Electron Builder の電子署名関連（含めるとセキュリティリスク）
# ============================================
*.p12
*.pfx
*.key
*.crt
*.cer

# ============================================
# パッケージマネージャのロックファイル（複数あれば 1 つに絞る）
# ============================================
# 採用: package-lock.json
# 除外: 他のパッケージマネージャのロックファイル
yarn.lock
pnpm-lock.yaml
bun.lockb

# ============================================
# 補助スクリプトの実行結果
# ============================================
*.zip-output/
benchmark-results/

# ============================================
# REQ-20260615-045 F — internal development resources excluded from
# the public repository.  Kept locally for development (CLAUDE.md is
# the canonical agent instruction set; dev-docs/ is the spec / design /
# build / font-validation reference).  Past history on origin/main
# still contains these files — a separate history-rewrite decision is
# required to scrub them retroactively.
# ============================================
/CLAUDE.md
/dev-docs/

# ============================================
# REQ-20260615-047 Phase 3 — local PII dictionary used by scripts/pii-scan.mjs
# and the pre-commit / pre-push hooks.  Must never be tracked — contains
# the actual blocklist words (owner name, personal paths, contact strings).
# A re-clone has no dictionary yet; the scanner falls back to the
# generic-pattern path block in that case.  Owner re-creates the file
# locally per dev-docs/RELEASE_CHECKLIST.md (also gitignored).
# ============================================
/.pii-blocklist

# Playwright runtime output
/test-results/
